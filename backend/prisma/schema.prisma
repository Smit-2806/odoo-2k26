datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("VENDOR") // Handled as string enum
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A user can be linked to one vendor profile (if role is VENDOR)
  vendorProfile VendorProfile?
  
  // Audits and actions
  createdRfqs   Rfq[]          @relation("RfqCreator")
  approvals     Approval[]
}

model VendorProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName    String
  taxId          String   @unique
  phone          String
  address        String
  website        String?
  status         String   @default("PENDING") // Handled as string enum
  verifiedAt     DateTime?
  businessFields String   // Comma-separated list for SQLite e.g. "IT,Logistics"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  rating         Float    @default(5.0)
  category       String   @default("Furniture")
  overdueInvoices Int     @default(0)

  quotations     Quotation[]
  assignments    RfqAssignment[]
}

model RfqAssignment {
  id        String        @id @default(uuid())
  rfqId     String
  rfq       Rfq           @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId  String
  vendor    VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([rfqId, vendorId])
}

model Rfq {
  id              String      @id @default(uuid())
  title           String
  description     String
  category        String      // Added to fix TS compile error on frontend
  status          String      @default("DRAFT") // Handled as string enum
  submissionDeadline DateTime
  deliveryTerms   String
  paymentTerms    String
  creatorId       String
  creator         User        @relation("RfqCreator", fields: [creatorId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           RfqItem[]
  quotations      Quotation[]
  purchaseOrders  PurchaseOrder[]
  assignments     RfqAssignment[]
}

model RfqItem {
  id          String   @id @default(uuid())
  rfqId       String
  rfq         Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  name        String
  description String?
  quantity    Int
  uom         String   // Unit of Measure, e.g., PCS, BOX, KG
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quotationItems QuotationItem[]
}

model Quotation {
  id            String    @id @default(uuid())
  rfqId         String
  rfq           Rfq       @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId      String
  vendor        VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  status        String    @default("SUBMITTED") // Handled as string enum
  validUntil    DateTime
  deliverySchedule String  // Delivery lead time/details
  paymentTerms  String
  notes         String?
  totalAmount   Float
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items         QuotationItem[]
  purchaseOrder PurchaseOrder?
  approvals     Approval[]
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  rfqItemId   String
  rfqItem     RfqItem   @relation(fields: [rfqItemId], references: [id], onDelete: Cascade)
  unitPrice   Float
  totalPrice  Float
  notes       String?
}

model PurchaseOrder {
  id              String        @id @default(uuid())
  poNumber        String        @unique // e.g. PO-2026-0001
  rfqId           String
  rfq             Rfq           @relation(fields: [rfqId], references: [id])
  quotationId     String        @unique
  quotation       Quotation     @relation(fields: [quotationId], references: [id])
  status          String        @default("DRAFT") // Handled as string enum
  totalAmount     Float
  shippingAddress String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  invoices        Invoice[]
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  status          String        @default("GENERATED") // Handled as string enum
  amount          Float
  invoiceDate     DateTime
  dueDate         DateTime
  fileUrl         String?       // Link to uploaded PDF
  pdfUrl          String?       // Actual backend generated PDF URL
  tax             Float         @default(0)
  subtotal        Float         @default(0)
  total           Float         @default(0)
  emailStatus     String        @default("PENDING")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Approval {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  approverId  String?
  approver    User?     @relation(fields: [approverId], references: [id])
  approved    Boolean
  status      String    @default("PENDING")
  stage       Int       @default(1)
  comments    String?
  createdAt   DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  category  String   // VENDOR, RFQ, APPROVAL, INVOICE, SYSTEM
  message   String
  timestamp DateTime @default(now())
  user      String
}
