datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  PROCUREMENT
  FINANCE
  VENDOR
}

enum VendorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RfqStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum QuotationStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum PoStatus {
  DRAFT
  SENT
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  SUBMITTED
  APPROVED
  PAID
  REJECTED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(VENDOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A user can be linked to one vendor profile (if role is VENDOR)
  vendorProfile VendorProfile?
  
  // Audits and actions
  createdRfqs   Rfq[]          @relation("RfqCreator")
  approvals     Approval[]
}

model VendorProfile {
  id             String       @id @default(uuid())
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName    String
  taxId          String       @unique
  phone          String
  address        String
  website        String?
  status         VendorStatus @default(PENDING)
  verifiedAt     DateTime?
  businessFields String[]     // e.g., ["IT", "Office Supplies", "Logistics"]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  quotations     Quotation[]
}

model Rfq {
  id              String      @id @default(uuid())
  title           String
  description     String
  status          RfqStatus   @default(DRAFT)
  submissionDeadline DateTime
  deliveryTerms   String
  paymentTerms    String
  creatorId       String
  creator         User        @relation("RfqCreator", fields: [creatorId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  items           RfqItem[]
  quotations      Quotation[]
  purchaseOrders  PurchaseOrder[]
}

model RfqItem {
  id          String   @id @default(uuid())
  rfqId       String
  rfq         Rfq      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  name        String
  description String?
  quantity    Int
  uom         String   // Unit of Measure, e.g., PCS, BOX, KG
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quotationItems QuotationItem[]
}

model Quotation {
  id            String          @id @default(uuid())
  rfqId         String
  rfq           Rfq             @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendorId      String
  vendor        VendorProfile   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  status        QuotationStatus @default(SUBMITTED)
  validUntil    DateTime
  deliverySchedule String       // Delivery lead time/details
  paymentTerms  String
  notes         String?
  totalAmount   Decimal         @db.Decimal(12, 2)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  items         QuotationItem[]
  purchaseOrder PurchaseOrder?
  approvals     Approval[]
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  rfqItemId   String
  rfqItem     RfqItem   @relation(fields: [rfqItemId], references: [id], onDelete: Cascade)
  unitPrice   Decimal   @db.Decimal(12, 2)
  totalPrice  Decimal   @db.Decimal(12, 2)
  notes       String?
}

model PurchaseOrder {
  id              String        @id @default(uuid())
  poNumber        String        @unique // e.g. PO-2026-0001
  rfqId           String
  rfq             Rfq           @relation(fields: [rfqId], references: [id])
  quotationId     String        @unique
  quotation       Quotation     @relation(fields: [quotationId], references: [id])
  status          PoStatus      @default(DRAFT)
  totalAmount     Decimal       @db.Decimal(12, 2)
  shippingAddress String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  invoices        Invoice[]
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  status          InvoiceStatus @default(SUBMITTED)
  amount          Decimal       @db.Decimal(12, 2)
  invoiceDate     DateTime
  dueDate         DateTime
  fileUrl         String?       // Link to uploaded PDF
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Approval {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  approverId  String
  approver    User      @relation(fields: [approverId], references: [id])
  approved    Boolean
  comments    String?
  createdAt   DateTime  @default(now())
}
